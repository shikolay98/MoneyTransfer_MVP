# ── Runtime ──────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=4000
WEB_URL=http://localhost:5173
API_URL=http://localhost:4000

# Comma-separated list of allowed origins for CORS and Socket.IO.
CORS_ORIGIN=http://localhost:5173

# Set to true when the API runs behind a reverse proxy (nginx, load balancer).
TRUST_PROXY=false

# ── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/moneytransfer_mvp?schema=public

# ── Auth / sessions ──────────────────────────────────────────────────────────
# In production both secrets MUST be replaced (the API refuses placeholders).
# Generate with: openssl rand -hex 32
COOKIE_NAME=mt_session
COOKIE_SECRET=change_me_cookie_secret_32_chars
JWT_SECRET=change_me_jwt_secret_32_chars
SESSION_TTL_HOURS=168

# ── Telegram Login ───────────────────────────────────────────────────────────
# Create a bot via @BotFather, then run /setdomain and bind your site domain.
# In production a real token is required (the API refuses the placeholder).
TELEGRAM_BOT_TOKEN=replace_with_bot_token
TELEGRAM_BOT_USERNAME=replace_with_bot_username
TELEGRAM_LOGIN_DOMAIN=localhost

# ── Seeded admin account ─────────────────────────────────────────────────────
# Used on first `prisma db seed` only. To reset a lost password re-run the
# seed with SEED_RESET_ADMIN_PASSWORD=true.
ADMIN_EMAIL=admin@local.test
ADMIN_PASSWORD=ChangeMe123!
ADMIN_NAME=Main Admin

# ── Frontend (Vite, build-time) ──────────────────────────────────────────────
# Leave VITE_API_URL empty for same-origin deployment behind nginx.
VITE_APP_NAME=Money Transfer
VITE_API_URL=http://localhost:4000
VITE_TELEGRAM_BOT_USERNAME=replace_with_bot_username
