{
  "name": "moneytransfer-mvp",
  "private": true,
  "version": "0.1.0",
  "packageManager": "npm@10.8.2",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently -n web,api -c cyan,green \"npm run dev --workspace @moneytransfer/web\" \"npm run dev --workspace @moneytransfer/api\"",
    "build": "npm run build --workspaces --if-present",
    "lint": "eslint .",
    "format": "prettier --check .",
    "format:write": "prettier --write .",
    "db:generate": "npm run prisma:generate --workspace @moneytransfer/api",
    "db:migrate": "npm run prisma:migrate --workspace @moneytransfer/api",
    "db:seed": "npm run prisma:seed --workspace @moneytransfer/api",
    "docker:postgres": "docker compose up -d postgres"
  },
  "devDependencies": {
    "@eslint/js": "^9.24.0",
    "@types/node": "^22.14.1",
    "concurrently": "^9.1.2",
    "eslint": "^9.24.0",
    "eslint-config-prettier": "^10.1.2",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.19",
    "globals": "^16.0.0",
    "prettier": "^3.5.3",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.29.0"
  }
}
